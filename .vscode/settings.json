{
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, .npmrc, .yarnrc, .yarnrc.yml, .pnpmfile.cjs, .nvmrc, .node-version, .npmignore",
    "tsconfig.json": "tsconfig.*.json, tsconfig-*.json, env.d.ts, *.d.ts",
    "vite.config.*": "vitest.config.*, postcss.config.*, tailwind.config.*, unocss.config.*, svgo.config.*, vite-env.d.ts",
    "eslint.config.*": ".eslintrc, .eslintrc.*, .eslintignore, eslint.config.ts, eslint.config.js, eslint.config.mjs, eslint.config.cjs",
    ".eslintrc.*": ".eslintignore",
    ".prettierrc": ".prettierrc.*, .prettierignore, prettier.config.*",
    ".prettierrc.*": ".prettierignore",
    "biome.json": "biome.jsonc",
    ".stylelintrc.*": ".stylelintignore, stylelint.config.*",
    "firebase.json": ".firebaserc, firestore.rules, firestore.indexes.json, storage.rules, database.rules.json, firebase-debug.log, remoteconfig.template.json",
    ".gitignore": ".gitattributes, .gitmodules, .gitmessage, .mailmap, .git-blame*, .github, .gitkeep",
    "readme.*": "readme*, README*, authors, backers*, changelog*, citation*, code_of_conduct*, codeowners, contributing*, contributors, copying, credits, governance.md, history.md, license*, maintainers, security.md, sponsors.md",
    "README.*": "readme*, README*, authors, backers*, changelog*, citation*, code_of_conduct*, codeowners, contributing*, contributors, copying, credits, governance.md, history.md, license*, maintainers, security.md, sponsors.md",
    "*.vue": "$(capture).vue.d.ts, $(capture).spec.ts, $(capture).test.ts, $(capture).spec.js, $(capture).test.js, $(capture).stories.ts, $(capture).stories.js",
    "App.vue": "app.vue, main.ts, main.js, style.css, styles.css",
    "*.ts": "$(capture).js, $(capture).d.ts, $(capture).d.ts.map, $(capture).js.map, $(capture).spec.ts, $(capture).test.ts, $(capture).min.ts",
    "*.js": "$(capture).js.map, $(capture).min.js, $(capture).d.ts, $(capture).spec.js, $(capture).test.js, $(capture).d.ts.map",
    "*.mjs": "$(capture).mjs.map, $(capture).d.mts",
    "*.cjs": "$(capture).cjs.map, $(capture).d.cts",
    "*.jsx": "$(capture).js, $(capture).spec.jsx, $(capture).test.jsx",
    "*.tsx": "$(capture).ts, $(capture).spec.tsx, $(capture).test.tsx, $(capture).stories.tsx",
    "*.css": "$(capture).css.map, $(capture).min.css",
    "*.scss": "$(capture).scss.map, $(capture).css, $(capture).min.css",
    "*.sass": "$(capture).sass.map, $(capture).css, $(capture).min.css",
    "*.less": "$(capture).less.map, $(capture).css, $(capture).min.css",
    "index.html": "favicon.*, logo.*, robots.txt, manifest.json, sitemap.xml, ads.txt, browserconfig.xml, humans.txt",
    "*.html": "$(capture).css, $(capture).js, $(capture).min.js, $(capture).min.css",
    "pubspec.yaml": ".flutter-plugins, .packages, .dart_tool, .flutter-plugins-dependencies, .metadata, pubspec.lock, build.yaml, analysis_options.yaml, all_lint_rules.yaml",
    "*.dart": "$(capture).g.dart, $(capture).freezed.dart",
    "dockerfile": "dockerfile*, .dockerignore, docker-compose.*, compose.*",
    "Dockerfile": "Dockerfile*, .dockerignore, docker-compose.*, compose.*",
    ".env": ".env.*, .envrc, env.d.ts",
    ".env.*": ".env.*.local",
    ".editorconfig": ".editorconfig.*",
    "babel.config.*": ".babelrc, .babelrc.*, babel-plugin-*",
    "*.config.js": "$(capture).config.ts, $(capture).config.mjs, $(capture).config.cjs",
    "jest.config.*": "jest.setup.*, jest.*.json",
    "playwright.config.*": "playwright.setup.*",
    "Cargo.toml": "Cargo.lock, rust-toolchain.toml, rustfmt.toml, clippy.toml, .cargo",
    "go.mod": "go.sum",
    "Gemfile": "Gemfile.lock, .ruby-version, .ruby-gemset",
    "composer.json": "composer.lock, phpunit.xml, phpunit.xml.dist, phpstan.neon, .php-cs-fixer.dist.php",
    "pom.xml": "mvnw, mvnw.cmd, .mvn",
    "build.gradle": "gradlew, gradlew.bat, gradle.properties, settings.gradle, .gradle",
    "CMakeLists.txt": "CMakePresets.json, CMakeUserPresets.json, .clang-format, .clang-tidy, .clangd",
    "pyproject.toml": "poetry.lock, uv.lock, setup.py, setup.cfg, MANIFEST.in, .python-version, requirements*.txt, tox.ini, .flake8",
    "*.py": "$(capture).pyi, $(capture)_test.py, test_$(capture).py"
  },
  "explorer.sortOrder": "type",
  "explorer.compactFolders": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit"
  },
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.git": true,
    "**/coverage": true,
    "**/.firebase": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/*.min.js": true,
    "**/*.min.css": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.firebase": true
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "files.associations": {
    "*.css": "tailwindcss"
  }
}
