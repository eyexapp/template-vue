{
  "name": "vue",
  "displayName": "Vue 3",
  "description": "Vue 3 SPA with Vite 7, Pinia state management, vue-i18n 11, Tailwind CSS 4, and Vue Router 4",
  "category": "frontend",
  "language": "typescript",
  "framework": "vue",
  "stack": ["vue-3", "typescript", "vite-7", "pinia", "vue-router-4", "tailwindcss-4", "vue-i18n-11", "vitest", "playwright"],
  "features": ["composition-api", "state-management", "routing", "i18n", "responsive", "testing", "e2e"],
  "commands": {
    "dev": "npm run dev",
    "build": "npm run build",
    "test": "npm run test:unit",
    "lint": "npm run lint"
  },
  "packageManager": "npm",
  "ci": {
    "workflowTemplate": "vue",
    "runner": "ubuntu-latest",
    "runtime": {
      "name": "node",
      "version": "20",
      "setup": "actions/setup-node@v4",
      "cache": "npm"
    },
    "services": {},
    "steps": {
      "install": "npm ci",
      "build": "npm run build",
      "test": "npm run test:unit",
      "lint": "npm run lint"
    }
  }
}
